{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Actions Runner Controller Group",
      groupName: "actions-runner-controller",
      matchDatasources: ["docker"],
      matchPackageNames: ["/gha-runner-scale-set-controller/", "/gha-runner-scale-set/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Authentik Group",
      groupName: "authentik",
      matchDatasources: ["docker"],
      matchPackageNames: ["/goauthentik/", "/goauthentik/proxy"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      sourceUrl: "https://github.com/goauthentik/authentik",
      minimumGroupSize: 2,
    },
    {
      description: "Barman Cloud Group",
      groupName: "barman-cloud",
      matchDatasources: ["docker", "github-releases"],
      matchPackagePatterns: ["cloudnative-pg/plugin-barman-cloud", "plugin-barman-cloud"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      separateMinorPatch: true,
      sourceUrl: "https://github.com/cloudnative-pg/plugin-barman-cloud",
      minimumGroupSize: 2,
    },
    {
      description: "CE-Transcript Group",
      groupName: "ce-transcript",
      matchDatasources: ["docker", "aqua"],
      matchPackageNames: ["/ce-transcript/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Cloudflared Group",
      groupName: "cloudflared",
      matchDatasources: ["docker", "aqua"],
      matchPackageNames: ["/cloudflared/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Flux Operator Group",
      groupName: "flux-operator",
      matchDatasources: ["docker"],
      matchPackageNames: ["/flux-operator/", "/flux-instance/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Guacamole Group",
      groupName: "guacamole",
      matchDatasources: ["docker"],
      matchPackagePatterns: ["guacamole"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Immich Group",
      groupName: "Immich",
      matchDatasources: ["docker"],
      matchPackageNames: ["/immich/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      separateMinorPatch: true,
      sourceUrl: "https://github.com/immich-app/immich",
    },
    {
      description: "Intel Device Plugins Group",
      groupName: "intel-device-plugins",
      matchDatasources: ["docker"],
      matchPackageNames: ["/intel-device-plugins-operator/", "/intel-device-plugins-gpu/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Kopiur Group",
      groupName: "kopiur",
      matchPackageNames: ["kopiur"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Kubernetes Group",
      groupName: "kubernetes",
      matchDatasources: ["docker"],
      matchPackageNames: [
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/",
      ],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 5,
    },
    {
      description: "Nvidia Group",
      groupName: "nvidia",
      matchDatasources: ["docker"],
      matchPackageNames: ["/nvidia/", "nvidia-device-plugin"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Obico Group",
      groupName: "Obico",
      matchDatasources: ["docker"],
      matchPackageNames: ["/obico/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      separateMinorPatch: true,
      sourceUrl: "https://github.com/gabe565/docker-obico",
    },
    {
      description: "Pangolin Group",
      groupName: "pangolin",
      matchDatasources: ["docker"],
      matchPackageNames: ["/pangolin-operator/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Qbittorrent Group",
      groupName: "qbittorrent",
      matchDatasources: ["docker"],
      matchPackageNames: ["/qbittorrent/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Rook-Ceph Group",
      groupName: "rook-ceph",
      matchDatasources: ["docker"],
      matchPackageNames: ["/rook-ceph/", "/rook-ceph-cluster/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Tailscale Group",
      groupName: "tailscale",
      matchDatasources: ["docker"],
      matchPackageNames: ["/tailscale/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
    },
    {
      description: "Talos Group",
      groupName: "talos",
      matchPackageNames: ["siderolabs/talos"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
    {
      description: "Toolhive Group",
      groupName: "toolhive",
      matchDatasources: ["docker"],
      matchPackageNames: ["/toolhive/"],
      group: { commitMessageTopic: "{{{groupName}}} group" },
      minimumGroupSize: 2,
    },
  ],
}
